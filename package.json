{
  "name": "markdown-docs-editor",
  "version": "1.0.0",
  "description": "A modern Markdown note-taking application built with Vue and Electron.",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "test:electron": "playwright test --config=playwright.electron.config.ts",
    "electron:serve": "concurrently \"npm run dev\" \"wait-on tcp:5173 && electron .\"",
    "electron:build": "vue-tsc && vite build && electron-builder"
  },
  "dependencies": {
    "@langchain/core": "^0.3.69",
    "@langchain/openai": "^0.5.18",
    "@types/dompurify": "^3.0.5",
    "cytoscape": "^3.30.4",
    "docxtemplater": "^3.67.5",
    "dompurify": "^3.3.1",
    "electron-is-dev": "^2.0.0",
    "gray-matter": "^4.0.3",
    "html2canvas": "^1.4.1",
    "inversify": "^7.10.8",
    "jszip": "^3.10.1",
    "katex": "^0.16.11",
    "langchain": "^0.3.36",
    "marked": "^17.0.1",
    "mathquill": "^0.10.1-a",
    "mermaid": "^11.4.1",
    "openai": "^4.104.0",
    "pizzip": "^3.1.3",
    "puppeteer": "^23.0.0",
    "reflect-metadata": "^0.2.2",
    "vue-router": "^4.6.4",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@electron/remote": "^2.1.2",
    "@playwright/test": "^1.49.0",
    "@tsconfig/node22": "^22.0.5",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^22.7.5",
    "@vitejs/plugin-vue": "^5.1.4",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "concurrently": "^9.2.1",
    "electron": "^30.5.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9.13.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.3.3",
    "typescript": "~5.6.2",
    "vite": "^5.4.8",
    "vite-plugin-vue-devtools": "^7.7.9",
    "vitest": "^2.1.4",
    "vue": "^3.5.12",
    "vue-tsc": "^2.1.6",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.mdnote.app",
    "productName": "MD Note",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico",
      "signingHashAlgorithms": [],
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "markdown",
    "editor",
    "electron",
    "vue",
    "desktop"
  ],
  "author": "Your Name",
  "license": "MIT"
}
