    // 返回引用信息（fragmentId、位置、状态等）
  }
  
  extractFragmentIds(content: string): string[] {
    // 提取所有引用的片段ID
  }
}
```

#### 3.4.2 FragmentReferenceRegistrationService（引用注册服务）

**职责**：注册和管理引用关系

```typescript
@injectable()
export class FragmentReferenceRegistrationService {
  // 注册引用（双向）
  async registerReference(
    documentId: string,
    fragmentId: string,
    position: number,
    length: number
  ): Promise<void> {
    // 1. 在 Document 中添加引用信息
    document.addFragmentReference(fragmentId, fragmentTitle, position, length);
    
    // 2. 在 KnowledgeFragment 中添加反向引用
    fragment.addReferencedDocument(documentId, documentTitle);
    
    // 3. 保存两个聚合
    await this.documentRepository.save(document);
    await this.fragmentRepository.save(fragment);
  }
  
  // 取消注册引用
  async unregisterReference(
    documentId: string,
    fragmentId: string
  ): Promise<void> {
    // 从两个聚合中移除引用关系
  }
}
```

#### 3.4.3 FragmentReferenceSyncService（引用同步服务）

**职责**：同步片段更新到所有引用文档

```typescript
@injectable()
export class FragmentReferenceSyncService {
  async syncFragmentUpdate(fragmentId: string): Promise<void> {
    // 1. 获取片段
    const fragment = await this.fragmentRepository.findById({ value: fragmentId });
    
    // 2. 获取所有已连接的引用
    const connectedReferences = fragment.getConnectedReferences();
    
    // 3. 更新每个引用文档
    for (const ref of connectedReferences) {
      if (ref.documentId.startsWith('file:')) {
        // 外部文件：更新文件缓存
        await this.syncExternalFile(ref.documentId, fragmentId, fragmentMarkdown);
      } else {
        // 数据库文档：更新文档引用信息
        const document = await this.documentRepository.findById({ value: ref.documentId });
        // 更新文档中的片段标题等信息
        // 注意：文档内容中保持引用标志，不替换为实际内容
        await this.documentRepository.save(document);
      }
    }
  }
}
```

**设计要点**：
- 只同步已连接的引用（`isConnected = true`）
- 文档内容中保持引用标志 `{{ref:fragmentId}}`，不替换为实际内容
- 实际内容替换在预览/导出时通过 `FragmentReferenceResolver` 进行

#### 3.4.4 FragmentReferenceResolver（引用解析服务）

**职责**：在预览/导出时，将引用标志替换为片段内容

```typescript
@injectable()
export class FragmentReferenceResolver {
  async resolveReferences(content: string, documentId: string): Promise<string> {
    // 1. 解析所有引用标志
    const references = this.parser.parseReferences(content);
    
    // 2. 从后往前替换，避免索引偏移
    for (let i = references.length - 1; i >= 0; i--) {
      const ref = references[i];
      
      // 3. 获取片段内容
      const fragment = await this.fragmentRepository.findById({ value: ref.fragmentId });
      
      // 4. 处理图片路径（复制到文档的assets目录）
      let fragmentMarkdown = fragment.toMarkdown();
      // ... 处理图片路径 ...
      
      // 5. 替换引用标志为片段内容
      resolvedContent = this.replaceAt(
        resolvedContent,
        ref.startIndex,
        ref.endIndex,
        fragmentMarkdown
      );
    }
    
    return resolvedContent;
  }
}
```

