{
  "name": "markdown-docs-editor",
  "version": "1.0.0",
  "description": "A Markdown editor with real-time preview, KaTeX, Mermaid, and export capabilities.",
  "main": "main.ts",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "electron:serve": "concurrently \"npm run dev\" \"wait-on tcp:5173 && electron .\"",
    "electron:build": "vue-tsc && vite build && electron-builder"
  },
  "dependencies": {
    "katex": "^0.16.11",
    "mermaid": "^11.4.1",
    "puppeteer": "^23.0.0",
    "docxtemplater": "^4.18.0",
    "pizzip": "^3.1.3",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@electron/remote": "^2.1.2",
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.7.5",
    "@vitejs/plugin-vue": "^5.1.4",
    "@vue/test-utils": "^2.4.6",
    "concurrently": "^9.0.1",
    "electron": "^30.0.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.13.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.3.3",
    "typescript": "~5.6.2",
    "vite": "^5.4.8",
    "vitest": "^2.1.4",
    "vue": "^3.5.12",
    "vue-tsc": "^2.1.6",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.markdown-docs-editor.app",
    "productName": "Markdown Docs Editor",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "markdown",
    "editor",
    "electron",
    "vue",
    "desktop"
  ],
  "author": "Your Name",
  "license": "MIT"
}
